# ============================================================
# RAG Pipeline — Central Configuration
# All services read from this file via docker-compose env_file
# Override per-service by setting variables in the service's
# environment block or by copying to .env.local
# ============================================================

# ── Service hosts (docker-compose service names) ────────────
# *_HOST = hostname OTHER services use to reach this service (Docker DNS name)
# *_BIND_HOST = address this service binds to INSIDE its own container (always 0.0.0.0)
EMBEDDER_BIND_HOST=0.0.0.0
RETRIEVER_BIND_HOST=0.0.0.0
GATEWAY_BIND_HOST=0.0.0.0
EMBEDDER_HOST=embedder
EMBEDDER_PORT=8001
RETRIEVER_HOST=retriever
RETRIEVER_PORT=8002
CACHE_HOST=redis-stack
CACHE_PORT=6379
LLM_HOST=llm
LLM_PORT=8080
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# ── Embedding ────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384
EMBEDDING_BATCH_SIZE=512
EMBEDDING_SINGLE_LATENCY_TARGET_MS=8
EMBEDDING_BATCH_LATENCY_TARGET_MS=180

# ── FAISS / Retriever ────────────────────────────────────────
FAISS_INDEX_PATH=/app/data/index.faiss
SQLITE_PATH=/app/data/index_meta.sqlite
FAISS_FLAT_MAX_CHUNKS=10000
FAISS_IVF_MAX_CHUNKS=1000000
FAISS_IVF_NPROBE=32
FAISS_HNSW_M=32
FAISS_HNSW_EF_SEARCH=64
RETRIEVER_DEFAULT_K=4
RETRIEVER_SIMPLE_K=4
RETRIEVER_COMPLEX_K=12
RETRIEVER_MULTIHOP_K1=8
RETRIEVER_MULTIHOP_K2=4

# ── Complexity Classifier ────────────────────────────────────
CLASSIFIER_COMPLEXITY_THRESHOLD=0.6
CLASSIFIER_TOKEN_WEIGHT=0.3
CLASSIFIER_ENTITY_WEIGHT=0.3
CLASSIFIER_CONJUNCTION_WEIGHT=0.2
CLASSIFIER_SUBQUERY_WEIGHT=0.2
CLASSIFIER_MAX_TOKENS_SCORE=50

# ── Semantic Cache ───────────────────────────────────────────
CACHE_SIMILARITY_THRESHOLD=0.92
CACHE_TTL_SECONDS=3600
CACHE_INDEX_NAME=idx:cache
CACHE_KEY_PREFIX=rag:cache:

# ── LLM ─────────────────────────────────────────────────────
LLM_MODEL_PATH=/app/models/mistral-7b-instruct-v0.2.Q4_K_M.gguf
LLM_CONTEXT_SIZE=4096
LLM_N_GPU_LAYERS=0
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.1
LLM_STREAM=false

# ── MMR Re-ranking ───────────────────────────────────────────
MMR_LAMBDA=0.7

# ── Ingestion ────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
INGEST_DATA_DIR=/app/data/raw
INGEST_SUPPORTED_EXTENSIONS=.pdf,.md,.txt

# ── Gateway routing targets (ms) ────────────────────────────
GATEWAY_CACHE_HIT_TARGET_MS=5
GATEWAY_SIMPLE_TARGET_MS=300
GATEWAY_COMPLEX_TARGET_MS=800

# ── Observability ────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=rag_grafana_pass

# ── Web Scraper ──────────────────────────────────────────────
SCRAPER_PORT=8003
# Comma-separated seed URLs — the scraper crawls from here
# Example: SCRAPER_SEED_URLS=https://docs.python.org/3/,https://realpython.com
SCRAPER_MAX_PAGES_PER_SEED=50
SCRAPER_MAX_DEPTH=2
SCRAPER_STAY_ON_DOMAIN=false
# Seed URLs to crawl (required)
SCRAPER_SEED_URLS=https://docs.python.org/3/,https://realpython.com

# Extra domains to allow when SCRAPER_STAY_ON_DOMAIN=true
SCRAPER_ALLOWED_DOMAINS=docs.example.com,blog.example.com

# URL patterns to skip (regex)
SCRAPER_EXCLUDE_PATTERNS=\.(jpg|jpeg|png|gif|svg|ico|css|js|woff|ttf|zip)$,/login,/signup

# URL patterns to always include even if excluded
SCRAPER_INCLUDE_PATTERNS=\.pdf$,/docs/
SCRAPER_REQUEST_TIMEOUT_S=15.0
SCRAPER_REQUEST_DELAY_S=0.5
SCRAPER_CONCURRENCY=5
SCRAPER_USER_AGENT=RAGPipelineBot/1.0
SCRAPER_OUTPUT_DIR=/app/data/raw
SCRAPER_OUTPUT_FORMAT=markdown
SCRAPER_RESPECT_ROBOTS_TXT=true
SCRAPER_MIN_CONTENT_LENGTH=200
# Automatically trigger ingestion after scraping completes
SCRAPER_AUTO_INGEST=true

# ── CI / Benchmark ───────────────────────────────────────────
BENCHMARK_N_QUERIES=500
BENCHMARK_P99_CACHED_MAX_MS=100
BENCHMARK_P99_COMPLEX_MAX_MS=800
BENCHMARK_REGRESSION_THRESHOLD_PCT=20

# ── AWS (production) ─────────────────────────────────────────
AWS_REGION=us-east-1
ECR_REGISTRY=123456789.dkr.ecr.us-east-1.amazonaws.com
ECS_CLUSTER_NAME=rag-pipeline-cluster
GATEWAY_CPU=1024
GATEWAY_MEMORY=2048
LLM_CPU=4096
LLM_MEMORY=16384
REDIS_NODE_TYPE=cache.t3.medium
ALERT_P99_THRESHOLD_MS=150