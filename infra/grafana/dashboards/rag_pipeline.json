{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Latency",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(rag_query_latency_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "P50 {{ route }}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_query_latency_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "P95 {{ route }}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(rag_query_latency_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "P99 {{ route }}"
        }
      ],
      "title": "Query Latency P50/P95/P99 by Route",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 0.1 },
          { "color": "red", "value": 0.8 }
        ] } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(rag_query_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99 Overall"
        }
      ],
      "title": "P99 Latency (all routes)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Cache",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.2 },
            { "color": "green", "value": 0.35 }
          ] }
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 10 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "value_and_name", "colorMode": "background" },
      "targets": [
        {
          "expr": "rate(rag_cache_hit_total{result=\"hit\"}[10m]) / (rate(rag_cache_hit_total{result=\"hit\"}[10m]) + rate(rag_cache_hit_total{result=\"miss\"}[10m]))",
          "legendFormat": "Cache Hit Rate"
        }
      ],
      "title": "Semantic Cache Hit Rate",
      "type": "gauge"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 10 },
      "id": 4,
      "targets": [
        {
          "expr": "rate(rag_cache_hit_total{result=\"hit\"}[1m])",
          "legendFormat": "Hits/s"
        },
        {
          "expr": "rate(rag_cache_hit_total{result=\"miss\"}[1m])",
          "legendFormat": "Misses/s"
        }
      ],
      "title": "Cache Hits vs Misses (rate/s)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 102,
      "title": "LLM & Retrieval",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [
          { "color": "red", "value": null },
          { "color": "yellow", "value": 10 },
          { "color": "green", "value": 20 }
        ] } }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 17 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        { "expr": "rag_llm_tokens_per_second", "legendFormat": "tok/s" }
      ],
      "title": "LLM Throughput (tokens/sec)",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 17 },
      "id": 6,
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(rag_retrieval_latency_ms_bucket[5m])) by (le, index_type))",
          "legendFormat": "P99 {{ index_type }}"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(rag_retrieval_latency_ms_bucket[5m])) by (le, index_type))",
          "legendFormat": "P50 {{ index_type }}"
        }
      ],
      "title": "Retrieval Latency by Index Type",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.85 },
            { "color": "green", "value": 0.91 }
          ] }
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 17 },
      "id": 7,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        { "expr": "rag_retrieval_recall_at_k", "legendFormat": "Recall@k" }
      ],
      "title": "Retrieval Recall@k",
      "type": "gauge"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "Error Rate",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "red" } } },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 24 },
      "id": 8,
      "targets": [
        {
          "expr": "sum(rate(rag_query_latency_seconds_count[1m])) by (route)",
          "legendFormat": "Total QPS {{ route }}"
        }
      ],
      "title": "Query Rate by Route",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["rag", "ai", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "RAG Pipeline — Full Observability",
  "uid": "rag-pipeline-v1",
  "version": 1
}
